# Supabase Configuration (for persistent storage)
# Get these from your Supabase Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — needed for Storage image uploads and bypassing RLS
# Get from: Supabase Project Settings > API > service_role key (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API Key (handled by platform, but useful for local dev)
GEMINI_API_KEY=

# Google OAuth (for user accounts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session secret — set a long random string in production
SESSION_SECRET=

# Google Cloud Storage (optional backup)
GCS_BUCKET_NAME=
