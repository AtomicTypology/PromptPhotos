# Supabase Configuration (for persistent storage)
# Get these from your Supabase Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API Key (handled by platform, but useful for local dev)
GEMINI_API_KEY=

# Google Cloud Configuration
# Set these in the AI Studio Settings menu
# Google OAuth setup:
# - Authorized JavaScript origin = your APP_URL
# - Authorized redirect URI = your APP_URL + /auth/callback
GOOGLE_CLIENT_ID=5945458063-1o4av51370qe3du5799ce0e5q2shh7vu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GCS_BUCKET_NAME=
SESSION_SECRET=prompt-studio-secret
# For local development use: http://localhost:3000
# For deployment use: your exact public base URL with no trailing slash
APP_URL=
