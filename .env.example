SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API Key (handled by platform, but useful for local dev)
GEMINI_API_KEY=

# Google Cloud Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GCS_BUCKET_NAME=
SESSION_SECRET=
